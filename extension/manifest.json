{
  "manifest_version": 3,
  "name": "Universal LLM Agent",
  "description": "Чат-агент для управления текущим сайтом прямо во вкладке.",
  "version": "1.0.0",
  "action": {
    "default_title": "Universal LLM Agent",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
